# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Vitest coverage (apps/mobile)
coverage/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Stray Next.js declaration file — never belongs in apps/mobile/
# (occasionally generated when something accidentally invokes the
# Next.js compiler from this dir during a typecheck or build run;
# see teardown 2026-04-28 for context). Defensive ignore so it
# can't reappear silently.
next-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
