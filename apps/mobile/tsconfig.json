{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@suppr/shared/*": [
        "../../src/lib/*"
      ],
      "@supabase/supabase-js": [
        "./node_modules/@supabase/supabase-js"
      ],
      "@suppr/nutrition-core": [
        "../../src/lib/nutrition-core/index.ts"
      ],
      "@suppr/nutrition-core/*": [
        "../../src/lib/nutrition-core/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
