+- (void)dietary_getDietaryQuantitySamplesForPermission:(NSDictionary *)input callback:(RCTResponseSenderBlock)callback
+{
+    NSString *permissionKey = [RCTAppleHealthKit stringFromOptions:input key:@"permissionKey" withDefault:nil];
+    if (permissionKey == nil) {
+        callback(@[RCTMakeError(@"permissionKey is required in options", nil, nil)]);
+        return;
+    }
+    HKObjectType *resolved = [self getReadPermFromText:permissionKey];
+    if (!resolved || ![resolved isKindOfClass:[HKQuantityType class]]) {
+        callback(@[RCTMakeError(@"Unsupported or unknown dietary permissionKey", nil, nil)]);
+        return;
+    }
+    HKQuantityType *type = (HKQuantityType *)resolved;
+
+    HKUnit *defaultUnit = [HKUnit gramUnit];
+    if ([permissionKey isEqualToString:@"EnergyConsumed"]) {
+        defaultUnit = [HKUnit kilocalorieUnit];
+    }
+
+    HKUnit *unit = [RCTAppleHealthKit hkUnitFromOptions:input key:@"unit" withDefault:defaultUnit];
+    NSUInteger limit = [RCTAppleHealthKit uintFromOptions:input key:@"limit" withDefault:HKObjectQueryNoLimit];
+    BOOL ascending = [RCTAppleHealthKit boolFromOptions:input key:@"ascending" withDefault:false];
+    NSDate *startDate = [RCTAppleHealthKit dateFromOptions:input key:@"startDate" withDefault:nil];
+    NSDate *endDate = [RCTAppleHealthKit dateFromOptions:input key:@"endDate" withDefault:[NSDate date]];
+    if(startDate == nil){
+        callback(@[RCTMakeError(@"startDate is required in options", nil, nil)]);
+        return;
+    }
+    NSPredicate *predicate = [RCTAppleHealthKit predicateForSamplesBetweenDates:startDate endDate:endDate];
+
+    [self fetchQuantitySamplesOfType:type
+                                unit:unit
+                           predicate:predicate
+                           ascending:ascending
+                               limit:limit
+                          completion:^(NSArray *results, NSError *error) {
+        if(results){
+            callback(@[[NSNull null], results]);
+            return;
+        } else {
+            NSLog(@"RNHealth: dietary quantity samples failed for %@: %@", permissionKey, error);
+            callback(@[RCTMakeError(@"An error occured while retrieving dietary quantity samples", error, nil)]);
+            return;
+        }
+    }];
+}
