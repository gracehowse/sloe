{
  "name": "suppr-mobile",
  "main": "expo-router/entry",
  "version": "1.0.7",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "start:maestro": "expo start --port 8081",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:android",
    "ios": "bash ./scripts/ios-run-device.sh",
    "ios:lan": "EXPO_IOS_LAN=1 bash ./scripts/ios-run-device.sh",
    "ios:simulator": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "ios:device": "bash ./scripts/ios-run-device.sh",
    "ios:usb-devices": "bash ./scripts/ios-usb-devices.sh",
    "ios:device:tunnel": "bash ./scripts/ios-device-with-tunnel.sh",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:ios:personal": "EXPO_IOS_PERSONAL_TEAM=1 expo prebuild --clean --platform ios",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:prune-stale-workspace": "rm -rf ios/mobile.xcworkspace",
    "ios:fix-workspace": "bash ./scripts/ensure-suppr-xcworkspace.sh",
    "ios:xcode": "npm run ios:prune-stale-workspace && npm run ios:fix-workspace && open ios/Suppr.xcworkspace",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node ./scripts/run-maestro-e2e.mjs",
    "test:e2e:verify-suite": "node ./scripts/verify-maestro-suite.mjs",
    "test:e2e:watch": "node ./scripts/maestro-watch.mjs",
    "test:screens:diff": "node ./scripts/maestro-screenshot-diff.mjs",
    "test:screens:update-baseline": "node ./scripts/maestro-screenshot-diff.mjs --update-baseline",
    "test:screens:tour": "node ./scripts/maestro-screenshot-tour.mjs",
    "test:detox:build": "detox build --configuration ios.sim.release",
    "test:detox": "detox test --configuration ios.sim.release",
    "test:detox:build:debug": "detox build --configuration ios.sim.debug",
    "test:detox:debug": "detox test --configuration ios.sim.debug",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.102.1",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-share-intent": "^5.1.1",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.10",
    "js-sha256": "^0.11.1",
    "lucide-react-native": "^1.8.0",
    "posthog-react-native": "^4.41.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health": "^1.19.0",
    "react-native-purchases": "^9.15.2",
    "react-native-purchases-ui": "^9.15.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "19.1.0",
    "detox": "^20.50.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "patch-package": "^8.0.1",
    "pixelmatch": "^7.1.1",
    "pngjs": "^7.0.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "private": true
}
