{
  "expo": {
    "name": "Suppr",
    "slug": "suppr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "suppr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supprclub.supprapp",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Suppr reads your steps, weight, body fat, and activity data from Apple Health to keep your tracker in sync.",
        "NSHealthUpdateUsageDescription": "Suppr only reads steps, weight, body fat, and activity from Apple Health to sync your tracker. It does not write data back to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "appleTeamId": "CRQBTX5797"
    },
    "android": {
      "intentFilters": [
        {
