              "scheme": "https",
              "host": "www.instagram.com",
              "pathPrefix": "/p"
            },
            {
              "scheme": "https",
              "host": "www.instagram.com",
              "pathPrefix": "/reel"
            },
            {
              "scheme": "https",
              "host": "instagram.com",
              "pathPrefix": "/p"
