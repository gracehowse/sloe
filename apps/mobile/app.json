{
  "expo": {
    "name": "Suppr",
    "slug": "suppr",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "suppr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supprclub.supprapp",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Suppr reads your steps, active energy, basal energy, workouts, weight, body fat, and any dietary entries you have in Apple Health so your Suppr tracker stays in sync with the rest of your Health data.",
        "NSHealthUpdateUsageDescription": "Suppr writes the calories, protein, carbohydrates, fat, and fibre of the meals you log so other apps on your phone can read your nutrition from Apple Health.",
        "ITSAppUsesNonExemptEncryption": false,
        "SupprBuildTag": "2026-05-01-C5-C6-C9c-household-netflix-weight-chart-health-sync"
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "appleTeamId": "CRQBTX5797"
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "www.instagram.com",
              "pathPrefix": "/p"
            },
            {
              "scheme": "https",
              "host": "www.instagram.com",
              "pathPrefix": "/reel"
            },
            {
              "scheme": "https",
              "host": "instagram.com",
              "pathPrefix": "/p"
            },
            {
              "scheme": "https",
              "host": "instagram.com",
              "pathPrefix": "/reel"
            },
            {
              "scheme": "https",
              "host": "www.tiktok.com"
            },
            {
              "scheme": "https",
              "host": "vm.tiktok.com"
            },
            {
              "scheme": "https",
              "host": "pin.it"
            }
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#4c6ce0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.supprclub.supprapp"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "supprWebUrl": "https://suppr-club.com",
      "supprApiUrl": "https://suppr-club.com",
      "supabaseUrl": "https://fnfgxsignmuepshbebrl.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZuZmd4c2lnbm11ZXBzaGJlYnJsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1NzYxMzksImV4cCI6MjA5MTE1MjEzOX0.tTOwtZLREE3sfU6rOjLMRJ5bKYQW_zPj9yZiotfBad4",
      "router": {},
      "eas": {
        "projectId": "16ff0460-233f-4126-b40e-4b5ad54057df"
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "react-native-health",
        {
          "healthSharePermission": "Suppr reads your steps, active energy, basal energy, workouts, weight, body fat, and any dietary entries you have in Apple Health so your Suppr tracker stays in sync with the rest of your Health data.",
          "healthUpdatePermission": "Suppr writes the calories, protein, carbohydrates, fat, and fibre of the meals you log so other apps on your phone can read your nutrition from Apple Health."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4c6ce0"
        }
      ],
      [
        "expo-share-intent",
        {
          "iosShareExtensionBundleIdentifier": "com.supprclub.supprapp.share-extension",
          "iosAppGroupIdentifier": "group.com.supprclub.supprapp",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Suppr to scan product barcodes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
