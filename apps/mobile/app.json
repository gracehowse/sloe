    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "react-native-health",
        {
          "healthSharePermission": "Suppr reads your steps, weight, body fat, and activity data from Apple Health to keep your tracker in sync.",
          "healthUpdatePermission": "Suppr only reads steps, weight, body fat, and activity from Apple Health to sync your tracker. It does not write data back to Apple Health."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E6F4FE"
        }
      ],
      [
        "expo-share-intent",
        {
          "iosShareExtensionBundleIdentifier": "com.supprclub.supprapp.share-extension",
          "iosAppGroupIdentifier": "group.com.supprclub.supprapp",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Suppr to scan product barcodes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
