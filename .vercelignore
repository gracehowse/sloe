# Shrinks `vercel deploy` uploads: Next.js builds from repo root via `npm ci` + `next build`.
# Do not list anything the build must read (app/, src/, public/, configs, package-lock.json, …).

# Dependencies & caches (installed fresh on Vercel)
node_modules
apps/mobile/node_modules

# Next / tooling output
.next
.turbo
dist
coverage

# Playwright / Vitest artifacts (CI-only; not part of Next bundle)
test-results
playwright-report
blob-report

# Expo / React Native native trees (hundreds of MB; not used by web build)
apps/mobile/ios
apps/mobile/android
apps/mobile/.expo
apps/mobile/build

# Repo content not imported by `next build`
tests
docs
scripts
# Root-only: CLI migrations. A bare `supabase` matches *any* path segment and would
# strip `src/lib/supabase/` (breaks `@/lib/supabase/serverAnonClient` on Vercel).
/supabase/

# Local / Vercel metadata
# NOTE: .git is intentionally NOT ignored (ENG-1366) — vercel.json's
# ignoreCommand runs `git diff` against the previous commit to skip builds
# for mobile-only pushes, and needs the shallow clone history Vercel already
# fetches (depth=10) to still be present at that step.
.vercel
.cursor
.DS_Store
