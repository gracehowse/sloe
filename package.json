    "mobile:dev": "npm run start --prefix apps/mobile",
    "mobile:dev:clear": "npm run start:clear --prefix apps/mobile",
    "mobile:dev:tunnel": "npm run start:tunnel --prefix apps/mobile",
    "mobile:prebuild": "npm run prebuild --prefix apps/mobile",
    "mobile:prebuild:ios:personal": "npm run prebuild:ios:personal --prefix apps/mobile",
    "mobile:ios": "npm run ios --prefix apps/mobile",
    "mobile:ios:device": "npm run ios:device --prefix apps/mobile",
    "mobile:ios:device:tunnel": "npm run ios:device:tunnel --prefix apps/mobile",
    "ios:device:tunnel": "npm run ios:device:tunnel --prefix apps/mobile",
    "mobile:ios:prebuild": "npm run ios:prebuild --prefix apps/mobile",
    "mobile:ios:xcode": "npm run ios:xcode --prefix apps/mobile",
    "mobile:test:e2e": "npm run test:e2e --prefix apps/mobile",
    "mobile:test:e2e:watch": "npm run test:e2e:watch --prefix apps/mobile"
