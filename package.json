{
  "name": "suppr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "node scripts/e2e-preflight.mjs && playwright test",
    "test:e2e:watch": "npm run mobile:test:e2e:watch",
    "test:e2e:headed": "node scripts/e2e-preflight.mjs && playwright test --headed",
    "test:e2e:debug": "node scripts/e2e-preflight.mjs && playwright test --debug",
    "test:e2e:ui": "node scripts/e2e-preflight.mjs && playwright test --ui",
    "test:e2e:ai": "node scripts/e2e-preflight.mjs && playwright test tests/e2e/ai",
    "build:icons": "node scripts/build-icons.mjs",
    "delete:seeded-recipes": "node --import tsx scripts/delete-seeded-recipes.ts",
    "check:migrations": "node --import tsx scripts/check-migration-drift.ts",
    "verify:production-env": "node --import tsx scripts/verify-production-env.ts",
    "mobile:lint": "npm run lint --prefix apps/mobile",
    "mobile:typecheck": "npm run typecheck --prefix apps/mobile",
    "mobile:test": "npm test --prefix apps/mobile",
    "ci:preflight": "npm run verify:production-env && npm run typecheck && npm test && npm run mobile:lint && npm run mobile:typecheck && npm run mobile:test",
    "prelaunch:checklist": "node --import tsx scripts/prelaunch-checklist.ts",
    "smoke:production": "node --import tsx scripts/production-smoke.ts",
