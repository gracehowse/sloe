{
  "permissions": {
    "allow": [
      "mcp__PostHog__exec"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Code changed. Remember to update tests, docs, and check web/mobile parity.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/auto-push-on-stop.sh"
          }
        ]
      }
    ]
  }
}
