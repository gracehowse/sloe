{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "storybook",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "storybook", "--", "--no-open", "--quiet"],
      "port": 6006,
      "autoPort": false
    },
    {
      "name": "prototypes",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs/prototypes", "-l", "4599"],
      "port": 4599,
      "autoPort": true
    },
    {
      "name": "brand",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs/brand", "-l", "4601"],
      "port": 4601,
      "autoPort": true
    }
  ]
}
