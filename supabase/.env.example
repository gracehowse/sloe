# Copy to `supabase/.env` (gitignored) before `supabase start` if you use local Auth
# with Apple enabled in `config.toml`.
#
# Generate the value: Apple Developer (.p8 key + Team ID + Key ID) → JWT client secret
# (rotates ~every 6 months). See Supabase docs:
# https://supabase.com/docs/guides/auth/social-login/auth-apple
#
# Hosted projects: set the Apple provider secret in the Supabase Dashboard
# (Authentication → Providers → Apple), not only here.

SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
