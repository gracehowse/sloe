# EAS Build: treat this repo as just the mobile app.
# The repo-root package.json is for the Next.js web app and pulls in
# conflicting deps (React 18 vs mobile's React 19). Exclude it so EAS
# only resolves apps/mobile/package.json on the builder.
#
# NOTE: /src MUST remain included — the mobile app imports shared nutrition
# and analytics code from ../../../src/* via Metro watchFolders.

# Web-only root files
/package.json
/package-lock.json
/node_modules
/.next
/next.config.*
/next-env.d.ts

# Web-only directories (NOT /src — mobile shares code from there)
/public
/tests
/e2e
/playwright.config.*
/vitest.config.*

# Supabase / scripts / docs — not needed for the mobile build
/supabase
/scripts
/docs
/.github
/.vscode

# Large / local-only
/.maestro
*.log
.DS_Store

# Drop heavyweight dirs inside the mobile app — EAS rebuilds these
apps/mobile/node_modules
apps/mobile/ios/Pods
apps/mobile/ios/build
apps/mobile/android/build
apps/mobile/android/.gradle
apps/mobile/android/app/build
