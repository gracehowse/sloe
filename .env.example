# GitHub Actions: optional repo secrets for CI — see docs/deployment/github-ci-secrets.md
# (NEXT_PUBLIC_SUPABASE_* / E2E_EMAIL / E2E_PASSWORD)

# Local E2E — Playwright (repo root `npm run test:e2e`) and Maestro (`apps/mobile` `npm run test:e2e`)
# Use a dedicated Supabase user in the SAME project as NEXT_PUBLIC_SUPABASE_*; profile must be onboarded
# or authenticated tests redirect to /onboarding and fail.
E2E_EMAIL=your-supabase-test-user@example.com
E2E_PASSWORD=your-test-password

# Playwright visual golden account — separate from E2E_EMAIL so baselines stay stable.
# Create with: npm run setup:e2e:visual-golden
E2E_VISUAL_EMAIL=gracehowse+visualgolden@outlook.com
E2E_VISUAL_PASSWORD=

# Maestro only: must match the exp:// URL Metro prints (port often 8081)
# EXPO_DEV_SERVER_URL=exp://127.0.0.1:8081

# Optional: point Playwright at a server you started yourself (see tests/e2e/README.md)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEB_SERVER=1

# Chromatic — Playwright E2E (CI chromatic.yml) and/or Storybook (npm run chromatic)
# CHROMATIC_PROJECT_TOKEN=

# Applitools Eyes — optional hosted visual AI (npm run test:e2e:applitools)
# APPLITOOLS_API_KEY=
# APPLITOOLS_BATCH_NAME=Suppr local
# APPLITOOLS_SERVER_URL=https://eyes.applitools.com

# Centercode — beta feedback / release announcements (NOT layout QA)
# CENTERCODE_BASE_URL=https://yourco.centercode.com
# CENTERCODE_API_KEY=
# CENTERCODE_PROJECT_KEY=
# CENTERCODE_RELEASE_TYPE_KEY=
# CENTERCODE_DOWNLOAD_URL=https://testflight.apple.com/join/XXXX

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron shared secret (required for every /api/cron/* and /api/push/* route)
# Generate a fresh 32-byte random value (e.g. `openssl rand -hex 32`) and set
# it both here and on the Vercel production environment. Vercel crons must
# include it as `X-Cron-Secret` per the configuration in vercel.json.
SUPPR_CRON_SECRET=

# Supabase Management API personal access token (alarm 6, ENG-509).
# Used by /api/cron/supabase-advisor-check to poll the Security +
# Performance advisors and emit findings to Sentry. Create at
# https://supabase.com/dashboard/account/tokens (single-use; revocable).
# Set on the Vercel production environment.
SUPABASE_PAT=

# USDA FoodData Central (required for nutrition verification)
USDA_FDC_API_KEY=your-fdc-api-key

# Edamam Food Database + Nutrition Analysis API (optional — branded + restaurant nutrition + recipe analysis)
# Free tier: 1000 req/day. Sign up at https://developer.edamam.com/food-database-api
# Same credentials power both the Food Database search and the Nutrition Analysis (recipe-level) API.
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# FatSecret API (optional — branded nutrition search)
# Use CONSUMER_KEY + CLIENT_SECRET (OAuth 2.0 names) OR legacy CONSUMER_SECRET — code accepts either pair.
FATSECRET_CONSUMER_KEY=
FATSECRET_CLIENT_SECRET=
# FATSECRET_CONSUMER_SECRET=
# FATSECRET_TIER=premier

# Verify-ingredients per-recipe concurrency. Default 8 (clamped 1..16).
# Bump from prior default of 4 (2026-05-15) to halve recipe-import wall
# time on the viral path. Set to 4 to rollback if upstream APIs push
# back; aggregate spike protection lives at the route layer, not here.
# VERIFY_INGREDIENTS_CONCURRENCY=8

# Anthropic (preferred AI vision provider — photo meal log, label-correction
# verify, recipe-import vision routes). When set, vision routes use Claude
# Sonnet 4.6 by default. Falls back to OPENAI_API_KEY if absent so the
# transition can be done route-by-route without breaking existing flows.
ANTHROPIC_API_KEY=

# OpenAI (legacy — Whisper transcription for voice-log, plus fallback for
# vision routes during the Claude migration). Once all routes are migrated
# to Claude this becomes Whisper-only.
OPENAI_API_KEY=

# Stripe (required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASE_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_BASE_ANNUAL=price_xxx_base_annual
STRIPE_PRICE_PRO_ANNUAL=price_xxx_pro_annual
# ENG-667 — optional EUR Pro SKUs (VAT-inclusive in Stripe dashboard).
# When unset, EU checkout falls back to the GBP price ids above.
STRIPE_PRICE_PRO_MONTHLY_EUR=price_xxx_pro_monthly_eur
STRIPE_PRICE_PRO_ANNUAL_EUR=price_xxx_pro_annual_eur

# Stripe Tax feature flag (round-6, 2026-04-19).
# Default `false` — ships the pre-round-4 tax-EXCLUSIVE copy on /pricing
# and does NOT pass `automatic_tax` / `billing_address_collection` to
# Stripe Checkout (prevents a 400 while Stripe Tax is inactive in the
# dashboard). Flip to `true` in prod env *in the same window* as
# activating Stripe Tax + setting `tax_behavior` on every Price — at
# that point /pricing starts rendering the tax-INCLUSIVE VAT line and
# Checkout starts calculating VAT.
STRIPE_TAX_ENABLED=false

# Upstash Redis (optional — distributed rate limiting; falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI cost circuit-breaker (Blocker 3, 2026-05-14)
# Two daily caps to keep a viral spike from running up a four-figure
# overnight AI bill. Both reset on UTC midnight. Backed by the same
# Upstash Redis instance as rate limiting (falls back to in-memory in
# dev). See docs/decisions/2026-05-14-ai-cost-circuit-breaker.md.
#
# Per-user daily call cap. Default 50.
AI_BUDGET_PER_USER_DAILY_CALLS=50
# Global daily spend cap in GBP (pounds, integer). Default £50.
AI_BUDGET_GLOBAL_DAILY_GBP=50
# Enforcement flag. When `false` the counters increment but no calls are
# blocked (dark-launch mode). Enforcement returns HTTP 503 with code
# `ai_capacity_reached` when a cap is hit.
# PRODUCTION: enabled `true` on 2026-06-17 (ENG-1158) — the cost breaker is
# now enforcing in Vercel prod (Upstash present; fails open for 5 min before
# closing on sustained Redis outage). Local dev stays `false` so local AI is
# not capped; flip locally only to exercise the 503 path.
AI_BUDGET_ENFORCEMENT_ENABLED=false

# App URL (optional — defaults to VERCEL_URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privacy policy contact (optional — public; defaults to privacy@suppr-club.com)
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@suppr-club.com

# Sentry (optional — error tracking)
# Browser: public DSN. Server: secret DSN (often same Sentry project, different client key).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time source-map upload (read by `withSentryConfig` in next.config.ts).
# Without these, prod stacktraces stay minified — captures still work, they're just unreadable.
# Create the auth token at https://<org-slug>.sentry.io/settings/auth-tokens/
# Recommended scope: `org:ci` (superset — covers project:releases + project:read for source maps).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog (optional — analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Mobile PostHog (optional — mobile analytics)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=

# Mobile → Next.js API base (dev only). Point the sim at local routes
# before they ship, e.g. http://127.0.0.1:3000 — or use npm run mobile:dev:local
EXPO_PUBLIC_API_URL=

# Mobile Sentry (optional — mobile error tracking)
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat (optional — mobile in-app purchases)
# Production: set the split-platform keys below. Both are read from EAS
# Secrets / `.env.local` and take precedence over the unified key.
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=
# Dev / sandbox: a single v2 unified key (e.g. `test_…`) works on both
# platforms. Used when neither platform-specific key above is set. Safe
# to commit to personal `.env.local`; don't ship to prod EAS.
EXPO_PUBLIC_REVENUECAT_API_KEY=
# Server webhook auth — must match RevenueCat dashboard → Integrations → Webhooks.
REVENUECAT_WEBHOOK_AUTH=
# Optional override for replay smoke (`npm run smoke:revenuecat`).
REVENUECAT_WEBHOOK_URL=

# Supabase local Docker (`supabase start`) — Apple OAuth secret for config.toml; NOT root .env.local.
# Copy supabase/.env.example → supabase/.env and set SUPABASE_AUTH_EXTERNAL_APPLE_SECRET there.
