# Cursor
.cursor/

# Claude Code local scheduler lock (machine-specific)
.claude/scheduled_tasks.lock
# Overnight-run guard state (machine-/run-specific). See
# docs/runbooks/overnight-unattended-runs.md.
.claude/overnight/
# Marketplace-installed Claude Code skills are per-user (not tracked); our own
# committed project skills (suppr-*) ARE tracked. CLAUDE.md is tracked too.
.claude/skills/*
!.claude/skills/suppr-*/
# Local patch bundles / git worktrees created by tooling (machine-specific).
.claude/patches/
.claude/worktrees/

# Office
~$*.docx
Suppr_Product_Audit.docx

.vercel

# Expo local
.expo/

# Accidental empty files (npm/yarn noise in apps/mobile)
apps/mobile/node
apps/mobile/suppr-mobile@*

# App Store Connect API keys (never commit these)
*.p8

# Fetched TestFlight feedback may contain tester emails / screenshots
docs/testflight-feedback/data/

# Maestro screenshot diff — only the baseline is tracked; latest/ and diff/
# are regenerated each Maestro run. See apps/mobile/.maestro/README.md
# (§ "Visual regression — screenshot diff").
apps/mobile/screenshots/latest/
apps/mobile/screenshots/diff/
# Ad-hoc agent sim screenshots — local debugging artefacts, never committed.
apps/mobile/screenshots/agent-check/
apps/mobile/screenshots/agent/*
!apps/mobile/screenshots/agent/.gitkeep
# Local archived snapshot outputs from visual-check.mjs etc.
apps/mobile/screenshots/archived-*/
apps/mobile/screenshots/pre-fix-*/

# Root-level visual-audit screenshot dumps (visual-check.mjs / visual-compare.mjs).
# Regenerated locally; never committed.
screenshots/

# Docs — Playwright/Maestro capture outputs (regenerated by tests); not versioned.
docs/screenshots/
docs/audits/*-sweep-screenshots/

# Per-worktree Maestro reliability scaffold state (machine-specific).
# `.metro-state` / `.metro.log` are written by scripts/maestro-worktree-up.sh.
# `artifacts/` are screenshots written by validation flows. See
# apps/mobile/.maestro/README.md (§ "Per-PR validation flows").
.maestro/.metro-state
.maestro/.metro.log
.maestro/artifacts/
scripts/out/

# Redesign flag-ON/OFF review captures (regenerable via `npm run capture:redesign:*`
# + tests/e2e/screenshots/redesign-flags-capture.spec.ts). The spec + scripts are
# versioned; the PNGs are not. Committed CI goldens tracked under ENG-838.
docs/audits/2026-05-31-redesign-web-capture/
# Maestro ad-hoc capture output (screenshots from manual capture runs).
apps/mobile/.maestro/capture/

# Working design-exploration notes — scratch, date-stamped, not canonical
# (canonical decisions live in docs/decisions/). Whole dir ignored so new
# dated explorations don't keep showing up as untracked.
docs/design-explorations/
# Stitch design→code workflow doc — local tooling (the Stitch MCP server moved
# to local scope; project .mcp.json is empty). File-scoped so docs/workflows/
# stays open for any genuinely-tracked workflow docs later.
docs/workflows/stitch-claude-code.md

# Generated brand-asset exploration (AI images — kept local, too heavy for git)
docs/brand/sloe/assets/gen/
.playwright-mcp/
tmp/
*.tsbuildinfo
